[Desktop Entry]
Type=Application
Name=Bursts
Comment=Screensaver effect: bursts
Exec=env XCURSOR_PATH=/nonexistent XCURSOR_THEME=none xterm -fullscreen -bg black -fg white -ms black -xrm "XTerm*pointerColorBackground: black" -xrm "XTerm*pointerMode: 2" -e /usr/libexec/local76/screensavers/bursts
Icon=local76-bursts
Terminal=false
Categories=Screensaver;
